<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/preview_share_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A2530"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/preview_share_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10333E"
            android:padding="24dp">

            <TextView
                android:id="@+id/preview_share_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Author Name"
                android:textColor="#E8F4F6"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/preview_share_school"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="School"
                android:textColor="#7FA6AE"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#26FFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/preview_share_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""Quote text here...""
                android:textColor="#DCEFF2"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/preview_share_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❝ Quote Filosofis"
                android:textColor="#8FB0B8"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
